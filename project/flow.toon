  process(query:str, language:str) → NLPPipelineResult    fan=17   PIPELINE:NLPPipeline.entry
  export_call_graph(result:AnalysisResult, output_path:str) → None fan=17   PIPELINE:MermaidExporter.entry
  run_benchmark(project_path:str)                         fan=16   fan=16
