  analyze_cpp(content:str, file_path:str, module_name:str, ext:str, stats:Dict) → Dict fan=26   !! side-effects
  analyze_csharp(content:str, file_path:str, module_name:str, stats:Dict) → Dict fan=25   !! side-effects
  analyze_rust(content:str, file_path:str, module_name:str, stats:Dict) → Dict fan=24   !! side-effects
  analyze_go(content:str, file_path:str, module_name:str, stats:Dict) → Dict fan=22   !! side-effects
  _summarize_functions(nodes:Dict[int, Dict[str, Any]], limit_decisions:int, limit_calls:int) → Dict[str, FuncSummary] fan=21   !! side-effects
  analyze_project(project_path:str) → AnalysisResult      fan=19   PIPELINE:ProjectAnalyzer.entry
  run_benchmark() → Dict                                  fan=18   fan=18
  _build_project_yaml(result:AnalysisResult, prev_evolution:List[Dict]) → Dict[str, Any] fan=18   PIPELINE:ProjectYAMLExporter.entry
  export(result:AnalysisResult, output_path:str, **kwargs) → None fan=18   PIPELINE:ToonExporter.entry
  process(query:str, language:str) → NLPPipelineResult    fan=17   PIPELINE:NLPPipeline.entry
  export_call_graph(result:AnalysisResult, output_path:str) → None fan=17   PIPELINE:MermaidExporter.entry

CONTRACTS:
  Pipeline: Cli_exports
    main()
      IN:  ()
      OUT: None
      SIDE-EFFECT: IO(print, print)

    _run_exports(args, result, output_dir:Path, source_path:Optional[Path])
      IN:  args, result, output_dir:Path, source_path:Optional[Path]
      OUT: None
      SIDE-EFFECT: IO(print)

    _export_single_project(args, result, output_dir:Path, formats:list, source_path:Optional[Path])
      IN:  args, result, output_dir:Path, formats:list, source_path:Optional[Path]
      OUT: None

    _export_code2logic(args, source_path:Path, output_dir:Path, formats:list[str]) → None
      IN:  args, source_path:Path, output_dir:Path, formats:list[str]
      OUT: None
      SIDE-EFFECT: IO(print, print, print)

    _normalize_code2logic_output(found:Path, target:Path, args) → List[Path]
      IN:  found:Path, target:Path, args
      OUT: List[Path]
      SIDE-EFFECT: IO(mkdir)
      INVARIANT: len(output) <= len(input)

    manage_toon_size(source_file:Path, output_dir:Path, max_kb:int, prefix:str, verbose:bool) → List[Path]
      IN:  source_file:Path, output_dir:Path, max_kb:int, prefix:str, verbose:bool
      OUT: List[Path]
      SIDE-EFFECT: IO(print, unlink, print)

    split_toon_file(source_file:Path, output_dir:Path, max_kb:int, prefix:str) → List[Path]
      IN:  source_file:Path, output_dir:Path, max_kb:int, prefix:str
      OUT: List[Path]
      SIDE-EFFECT: IO(read_text)

    _split_by_lines(source_file:Path, output_dir:Path, max_kb:int, prefix:str) → List[Path]
      IN:  source_file:Path, output_dir:Path, max_kb:int, prefix:str
      OUT: List[Path]
      SIDE-EFFECT: IO(read_text)

    _write_chunk(output_dir:Path, prefix:str, chunk_num:int, content:str) → Path
      IN:  output_dir:Path, prefix:str, chunk_num:int, content:str
      OUT: Path
      SIDE-EFFECT: IO(write_text)

  Pipeline: Analysis
    analyze_file(file_path:str, module_name:str) → Dict
      IN:  file_path:str, module_name:str
      OUT: Dict
      SIDE-EFFECT: IO(read_text)

    _analyze_python(content:str, file_path:str, module_name:str) → Dict
      IN:  content:str, file_path:str, module_name:str
      OUT: Dict
      SIDE-EFFECT: cache(self.cache.get, self.cache.put)

    _analyze_ast(tree:ast.AST, file_path:str, module_name:str, content:str) → Dict
      IN:  tree:ast.AST, file_path:str, module_name:str, content:str
