TRANSFORMS (fan-out ≥10):
  analyze_typescript_js(content:str, file_path:str, module_name:str, ext:str, stats:Dict) → Dict fan=41   !! mutation-heavy
  analyze_php(content:str, file_path:str, module_name:str, stats:Dict) → Dict fan=35   !! mutation-heavy
