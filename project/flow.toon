# code2llm/flow | 887 func | 12 pipelines | 14 hub-types | 2026-03-25

PIPELINES[12] (Analysis:7, Core:1, Export:4):
  Cli_exports [Export]: ? → Path
              → main()                                  CC=7    IO ▶
              → _run_exports(args, result, output_dir:Path, source_path:Optional[Path]) CC=7    IO
              → _export_single_project(args, result, output_dir:Path, formats:list, source_path:Optional[Path]) CC=5    pure
              → _export_code2logic(args, source_path:Path, output_dir:Path, formats:list[str]) → None CC=6    IO
              → _normalize_code2logic_output(found:Path, target:Path, args) → List[Path] CC=2    IO
              → manage_toon_size(source_file:Path, output_dir:Path, max_kb:int, prefix:str, verbose:bool) → List[Path] CC=8    IO
              → split_toon_file(source_file:Path, output_dir:Path, max_kb:int, prefix:str) → List[Path] CC=3    IO
              → _split_by_lines(source_file:Path, output_dir:Path, max_kb:int, prefix:str) → List[Path] CC=8    IO
              → _write_chunk(output_dir:Path, prefix:str, chunk_num:int, content:str) → Path CC=2    IO ■
