    _process_class(node:ast.ClassDef, file_path:str, module_name:str, result:Dict) → None
      IN:  node:ast.ClassDef, file_path:str, module_name:str, result:Dict
      OUT: None
      SIDE-EFFECT: pure

    _process_function(node:ast.FunctionDef, file_path:str, module_name:str, result:Dict, class_name:Optional[str]) → None
      IN:  node:ast.FunctionDef, file_path:str, module_name:str, result:Dict, class_name:Optional[str]
