  analyze_streaming(project_path:str, _output_callback:Optional[callable]) → Iterator[Dict] fan=16   PIPELINE:StreamingAnalyzer.entry
  _build_project_yaml(result:AnalysisResult, prev_evolution:List[Dict]) → Dict[str, Any] fan=16   PIPELINE:ProjectYAMLExporter.entry
  _render(data:Dict[str, Any]) → str                      fan=16   PIPELINE:HTMLDashboardGenerator.entry

CONTRACTS:
  Pipeline: Cli_exports
    main()
      IN:  ()
      OUT: None
      SIDE-EFFECT: IO(print, print)

    _run_exports(args, result, output_dir:Path, source_path:Optional[Path])
      IN:  args, result, output_dir:Path, source_path:Optional[Path]
      OUT: None
      SIDE-EFFECT: IO(print)

    _export_single_project(args, result, output_dir:Path, formats:list, source_path:Optional[Path])
